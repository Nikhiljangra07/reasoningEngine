# =============================================================================
# Provider API keys
# =============================================================================
#
# PRIMARY PATH — OpenRouter (recommended)
# Single key, all providers. The engine routes per-call via src/llm/provider_map.py.
# Get one at https://openrouter.ai/keys
# Paste your key here:
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# -----------------------------------------------------------------------------
# DIRECT PROVIDER KEYS (optional)
# -----------------------------------------------------------------------------
# Leave these blank unless you want to bypass OpenRouter for a specific
# provider. The current client.py only reads OPENROUTER_API_KEY (with
# ANTHROPIC_API_KEY as a legacy fallback) — the keys below are declared
# so you have one place to paste them when we wire up direct-provider
# routing later.

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
# Also accepted as a legacy fallback for OPENROUTER_API_KEY by client.py.
ANTHROPIC_API_KEY=

# OpenAI (GPT) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini — https://aistudio.google.com/apikey
# (some SDKs expect GEMINI_API_KEY — set whichever your SDK reads)
GOOGLE_API_KEY=
GEMINI_API_KEY=

# xAI (Grok) — https://console.x.ai
XAI_API_KEY=


# =============================================================================
# MCP capabilities
# =============================================================================
#
# When these are set at server startup, the corresponding capability flips
# from MISSING → AVAILABLE in the registry and triage can fire the MCP.
# Leaving them blank is fine — the registry stays honest and the dispatcher
# surfaces "would you like to connect github?" offers instead.

# Context7 — on-demand library / API documentation (https://context7.com).
# Set to 1 / true / yes to enable. No API key required for basic usage.
# When enabled, the `docs` capability flips to AVAILABLE and triage can
# request library docs grounding. Operator-opt-in by design (Constellax
# refuses outbound calls without explicit consent).
CONTEXT7_ENABLED=
# Override the API root if Context7's endpoints move or you proxy them.
# Default: https://context7.com/api/v1
CONTEXT7_API_ROOT=
# Optional API key for future paid-tier accounts (not required today).
CONTEXT7_API_KEY=


# =============================================================================
# Server configuration
# =============================================================================
PORT=8100
HOST=0.0.0.0

# CORS — comma-separated list of allowed origins, or "*" for all
# In production, set to your actual frontend domain(s)
CORS_ORIGINS=*


# =============================================================================
# Engine configuration
# =============================================================================

# Effort tier — default iteration budget when a request does not specify one.
# Allowed values: low | medium | high
#   low    → 3 iterations
#   medium → 6 iterations
#   high   → 10 iterations
# See src/llm/effort.py.
LORA_EFFORT=medium

# Legacy raw iteration overrides (still honored by server.py if a request
# passes max_iterations directly). Effort tier above is the preferred control.
DEFAULT_MAX_ITERATIONS=2
MAX_PHASE2_ITERATIONS=6
MAX_PHASE1_SUMMARY_CHARS=20000
MAX_QUESTION_CHARS=8000
