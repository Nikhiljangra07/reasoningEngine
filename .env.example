# =============================================================================
# Constellax — environment variables
# =============================================================================
#
# This file is the canonical list of every env var the backend reads. Copy
# to .env for local dev. For Railway, set the same keys under the service's
# Variables tab.
#
# Convention:
#   - "Truthy" means anything except "", "0", "false", "no", "off".
#   - Keys left blank below show the safe default for that var.
#   - MCP capabilities are HONEST: a capability flips MISSING → AVAILABLE
#     only when its gate is set AND its dependency is wired. Picker
#     selection then grants per-turn consent.
#
# Categories (in order):
#   1. LLM provider API keys
#   2. Storage — Neo4j + Redis
#   3. MCP capabilities (toggleable per deployment)
#   4. Server runtime (port, CORS, logging)
#   5. Engine tuning (effort, iteration budgets)
#   6. Memory V2 + Decision Trace sweepers
#   7. Embedding + Gemini auxiliary models
#
#
# =============================================================================
# DEPLOYMENT CHECKLIST — what to set on Railway before going live
# =============================================================================
#
# REQUIRED (production WILL NOT work without these):
#
#   OPENROUTER_API_KEY      LLM routing for every chat / wander call
#                           https://openrouter.ai/keys                 [§1]
#
#   NEO4J_URI               Master memory graph (Thinking Room threads +
#   NEO4J_USERNAME          Wandering Room sessions/reports/jobs).
#   NEO4J_PASSWORD          Aura Pro is the production target; Aura Free
#                           https://console-preview.neo4j.io/aura/      [§2]
#
#   CONSTELLAX_DB_BACKEND=neo4j   Selector — locks the production path.   [§2]
#
#   SUPABASE_JWT_SECRET     Verifies frontend's Bearer tokens. Required
#                           the moment auth is enforced; setting it now
#                           is safe (middleware is a no-op until enforced)
#                           Supabase dashboard → Settings → API           [§0]
#
# STRONGLY RECOMMENDED (Wandering Room half-baked without these):
#
#   ANTHROPIC_API_KEY       (a) PDF math/code extraction (F1) — required;
#                           (b) optional legacy fallback for the LLM client
#                           https://console.anthropic.com/settings/keys   [§1]
#
#   EXA_API_KEY             Neural search + /findSimilar — the cross-domain
#                           analogy primitive that makes Wandering Room
#                           different from a vanilla search assistant.
#                           Free 1000 req/mo; ~$0.005/req above.
#                           https://dashboard.exa.ai/                     [§3]
#
#   TAVILY_API_KEY          Lexical search baseline. Without it, wandering
#                           falls through to DuckDuckGo HTML — works, but
#                           weaker snippets.
#                           https://app.tavily.com/                       [§3]
#
# OPTIONAL (graceful degradation if absent):
#
#   JINA_API_KEY            Higher RPM on Jina Reader. Public endpoint
#                           works at 20 RPM without a key.
#                           https://jina.ai/reader/                       [§3]
#
#   GOOGLE_API_KEY or       Search router (decides whether a question
#   GEMINI_API_KEY          needs live web data) + Memory V2 embedding.
#                           Falls back to regex heuristic without it.
#                           https://aistudio.google.com/apikey            [§1]
#
#   OPENAI_API_KEY          Bypass OpenRouter for OpenAI specifically.
#                           https://platform.openai.com/api-keys          [§1]
#
#   XAI_API_KEY             Bypass OpenRouter for Grok specifically.
#                           https://console.x.ai                          [§1]
#
# WANDERING ROOM FEATURE DEPENDENCIES (cross-reference):
#
#   F1 — PDF math parsing  requires ANTHROPIC_API_KEY                    [§3]
#   F3 — Past wanders list requires Neo4j (§2) + CONSTELLAX_DB_BACKEND   [§2]
#   F5 — Job durability    requires Neo4j (§2) + CONSTELLAX_DB_BACKEND   [§2]
#                           (without Neo4j, wanders survive lid-close but
#                            not server restarts; in-memory fallback is
#                            silently used)
#   D4 — Retrieval mesh    EXA_API_KEY + (TAVILY_API_KEY or DDG fallback)
#                           + (JINA_API_KEY or public 20 RPM)              [§3]
#
# Anything not in this checklist has a working default. See the per-section
# notes below for fine-tuning knobs.


# =============================================================================
# 0. Authentication — Supabase JWT verification (Phase 3A: non-breaking)
# =============================================================================
#
# When SUPABASE_JWT_SECRET is set, the backend's auth middleware verifies
# HS256-signed Bearer tokens in the Authorization header and attaches a
# VerifiedUser to request.state. When unset, the middleware is a no-op:
# every request flows through with verified_user=None and the existing
# body-supplied `user_id` is the only identity signal.
#
# Endpoint enforcement (require_auth) is currently OFF everywhere — that
# flips on in Phase 3C, after the frontend can send JWTs from a real
# login flow. Setting this var today is safe but has no effect on
# behavior until the frontend changes.
#
# How to get the secret:
#   1. Supabase dashboard → Project → Settings → API
#   2. Copy the value labeled "JWT Secret" (NOT the anon/public key)
#   3. Paste below (or into Railway → Variables)
#
# This is a SERVER-ONLY secret. Never expose it to the frontend.
SUPABASE_JWT_SECRET=


# =============================================================================
# 1. LLM provider API keys
# =============================================================================
#
# PRIMARY PATH — OpenRouter (recommended)
# Single key, all providers. The engine routes per-call via src/llm/provider_map.py.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# -----------------------------------------------------------------------------
# DIRECT PROVIDER KEYS (optional — bypass OpenRouter for one provider)
# -----------------------------------------------------------------------------
# Anthropic (Claude) — https://console.anthropic.com/settings/keys
#
# Used in TWO places:
#   1. REQUIRED for Wandering Room's PDF math/code extraction (F1).
#      Without it, PDFs from arXiv/research papers get garbled LaTeX
#      via Jina Reader instead of being parsed by Claude's native
#      PDF input. See §3 → "PDF math/code extraction" below.
#   2. Optional legacy fallback for OPENROUTER_API_KEY in client.py
#      — direct Anthropic path instead of routing through OpenRouter.
#
# Set this even if you're using OpenRouter for the main LLM path — F1
# is the only feature that bypasses OpenRouter and goes direct.
ANTHROPIC_API_KEY=

# OpenAI (GPT) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini — https://aistudio.google.com/apikey
# Both names are accepted; set whichever your SDK / our code path reads first.
# Used by: search_router, iteration_metadata, embedding_service, decision_trace_classifier.
GOOGLE_API_KEY=
GEMINI_API_KEY=

# xAI (Grok) — https://console.x.ai
XAI_API_KEY=


# =============================================================================
# 2. Storage — Neo4j (anchors + threads) + Redis (legacy thread store)
# =============================================================================
#
# Neo4j is the unified memory backend. Stores:
#   - Thinking Room: :Thread + :Iteration nodes
#   - Wandering Room: :WanderingSession + :WanderingReport +
#     :WanderingDiscardedClue + :WanderingJob nodes (the last one is the
#     F5 durability mirror — without Neo4j configured, wandering jobs
#     survive tab/lid close but NOT server restarts; in-memory fallback
#     is silently used and a one-line warning is logged at startup)
#   - Sidebar metadata: WanderingStore.sessions_metadata reads from
#     these same nodes for the GET /api/v2/wandering/sessions endpoint
#     (F3+F7 unified — past wanders list).
#
# Aura Free tier works for dev: https://console-preview.neo4j.io/aura/
# Aura Pro is the production path (decision committed 2026-05-27).
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Embedding vector dimension for Neo4j vector index.
# Must match GRAPHIFY_EMBEDDING_MODEL's output dimension (gemini-embedding-001 = 1536).
NEO4J_EMBEDDING_DIM=1536

# Backend selector for thread storage. "neo4j" is the only supported value
# in production; "falkor" is preserved for the legacy local-dev path.
CONSTELLAX_DB_BACKEND=neo4j

# Legacy local-dev path: filesystem-backed conversation store.
# Set only if you intentionally want the JSON-on-disk legacy store
# (testing migrations, debugging schema drift). Leave blank in production.
CONSTELLAX_CONVERSATION_STORE_PATH=

# Redis URL — used only when CONSTELLAX_DB_BACKEND=falkor (legacy).
# Format: redis://[:password@]host:port/db
CONSTELLAX_REDIS_URL=


# =============================================================================
# 3. MCP capabilities (per-deployment toggles)
# =============================================================================
#
# Each capability is OFF by default. Set the gate to enable. The capability
# stays MISSING in the registry until both the gate is set AND its
# dependency is wired — picker selection then grants per-turn consent.

# -----------------------------------------------------------------------------
# Web Search (Tavily primary, DuckDuckGo HTML fallback)
# -----------------------------------------------------------------------------
# Tavily is LLM-optimized — 1000 free queries/month, then $0.0075/query.
# Get a key at https://app.tavily.com/. When unset, DuckDuckGo's free HTML
# endpoint is used automatically — same wire shape, weaker snippets.
# Either way the `web_search` capability is AVAILABLE; the picker still
# controls whether it fires per turn (ambient-gate added Tier 1).
TAVILY_API_KEY=

# Model used by the LLM-based search router (decides whether the question
# needs web data, rewrites the query). Falls back to a regex heuristic if
# no Gemini/Google key is set.
SEARCH_ROUTER_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------------
# Wandering Room retrieval mesh — Exa + Jina Reader (decisions doc D4)
# -----------------------------------------------------------------------------
# Exa is the cross-domain-analogy differentiator for Wandering Room.
# Neural search (embedding proximity, not keyword) returns conceptually-
# similar pages even when the words don't overlap; /findSimilar takes a
# URL and returns embedding-adjacent URLs (the chaos-hop primitive).
#
# Free tier: 1000 requests/month. Above: ~$0.005/request. Get a key at
# https://dashboard.exa.ai/. When unset, wandering falls back to the
# Tavily → DDG chain — Wandering Room still functions, but loses the
# cross-domain semantic advantage that distinguishes it from a vanilla
# search-augmented assistant.
EXA_API_KEY=

# Jina Reader extracts clean markdown from any URL. Used by the tier-2
# escalation gate in src/wandering/agent.py — when a tier-1 snippet
# sweep shows borderline match signal (≥1 node matched, but neither
# essence nor mechanism is strong yet), the agent re-fetches the page
# via Jina to get a 10–20k-char body and re-matches.
#
# Without a key, Jina Reader works at 20 RPM via the public endpoint
# (https://r.jina.ai/<URL>) — fine for solo-launch scale. With a key:
# higher RPM and priority queuing. Get one at https://jina.ai/reader/
# (free credits at signup; pay-as-you-go beyond).
JINA_API_KEY=

# -----------------------------------------------------------------------------
# PDF math/code extraction (F1 — math/code/figure-aware)
# -----------------------------------------------------------------------------
# When a wandering agent's tier-2 escalation hits a PDF URL, Jina Reader
# garbles LaTeX equations and drops figures. The PDF extractor routes
# PDFs through Anthropic's native PDF-input API instead — preserves math
# as LaTeX, code blocks fenced, figures as italicised captions.
#
# Requires ANTHROPIC_API_KEY (defined above in section 1). Without it,
# PDFs fall through to Jina automatically — degraded math fidelity but
# wandering still works.
#
# Model override — defaults to claude-sonnet-4-5. Override only if a
# newer model gives better PDF understanding for your domain.
ANTHROPIC_PDF_MODEL=claude-sonnet-4-5

# -----------------------------------------------------------------------------
# Context7 (on-demand library / API documentation) — https://context7.com
# -----------------------------------------------------------------------------
# Truthy → registers the `docs` handler and flips the capability AVAILABLE.
# No API key required for basic usage; CONTEXT7_API_KEY hooks future paid tier.
CONTEXT7_ENABLED=
CONTEXT7_API_ROOT=https://context7.com/api/v1
CONTEXT7_API_KEY=

# -----------------------------------------------------------------------------
# Browser / Playwright (Tier 2 — local browser automation)
# -----------------------------------------------------------------------------
# Drive a real browser for UI-verification questions (JS executed, full DOM).
# Truthy → registers the `browser` handler. Picker selection grants per-turn
# consent.
#
# Local install (Mac dev):
#     source .venv/bin/activate
#     pip install playwright
#     playwright install chromium       # ~200MB into ~/Library/Caches/ms-playwright
#
# Railway deployment: requires playwright + system browser deps in the
# container image. Recommend a Dockerfile that runs the same two commands
# above plus `playwright install-deps chromium` for the OS libraries.
# When the package or browsers are missing at runtime, open_url returns
# a clean ok=False snapshot with an install hint — server keeps running.
PLAYWRIGHT_ENABLED=

# Browser engine. Allowed: chromium | firefox | webkit. chromium is the
# smallest install and the default. Unknown values fall back to chromium
# with a warning in the logs.
PLAYWRIGHT_BROWSER=chromium

# Run headless (no UI). Truthy = headless. Set 0 only when debugging locally
# with a visible browser window.
PLAYWRIGHT_HEADLESS=1

# Per-navigation timeout in milliseconds. Clamped to a 1000ms floor.
PLAYWRIGHT_TIMEOUT_MS=20000

# Cap on extracted body text (characters) before injection into the prompt.
# Prevents one giant page from blowing the prompt budget.
PLAYWRIGHT_TEXT_CHAR_CAP=6000


# =============================================================================
# 4. Server runtime
# =============================================================================
PORT=8100
HOST=0.0.0.0

# CORS — comma-separated list of allowed origins, or "*" for all.
# Production: lock to your actual frontend domain(s).
CORS_ORIGINS=*

# Python logging level. INFO is the right default; DEBUG is noisy.
LOG_LEVEL=INFO

# Observability log — per-LLM-call structured JSON records.
# Truthy = enabled (default). Path is configurable; default is logs/llm-calls.log.
OBS_LOG=1
OBS_LOG_PATH=


# =============================================================================
# 5. Engine tuning (effort + iteration budgets)
# =============================================================================
#
# Effort tier — default iteration budget when a request does not specify one.
# Allowed: low | medium | high
#   low    → 3 iterations
#   medium → 6 iterations
#   high   → 10 iterations
# See src/llm/effort.py.
CONSTELLAX_EFFORT=medium

# Legacy raw iteration overrides (still honored when a request passes
# max_iterations directly). Prefer CONSTELLAX_EFFORT as the control surface.
# (Legacy LORA_-prefixed names still work as fallbacks for existing deployments.)
DEFAULT_MAX_ITERATIONS=2
MAX_PHASE2_ITERATIONS=6

# Question + summary size limits.
MAX_QUESTION_CHARS=8000
MAX_PHASE1_SUMMARY_CHARS=20000


# =============================================================================
# 6. Memory V2 + Decision Trace sweepers
# =============================================================================
#
# Memory V2 retrieval at request time. Truthy = on (default).
# Turn off for debugging stale-memory issues; only do this in dev.
CONSTELLAX_MEMORY_RECALL_ENABLED=1

# Decision Trace sweeper — consolidates inactive threads into anchors.
# Runs in a background task; safe to leave on.
CONSTELLAX_DT_SWEEP_ENABLED=1
CONSTELLAX_DT_IDLE_SEC=1800          # 30 minutes idle → eligible for sweep
CONSTELLAX_DT_BATCH=50               # threads consolidated per sweep cycle
CONSTELLAX_DT_INTERVAL_SEC=300       # 5 minutes between sweep cycles

# Legacy sweeper (predecessor to DT_SWEEP). Both are off-by-default-safe.
CONSTELLAX_SWEEP_ENABLED=1
CONSTELLAX_SWEEP_INTERVAL_SECONDS=3600


# =============================================================================
# 7. Embedding + Gemini auxiliary models
# =============================================================================
#
# Embedding model used by graphify / Memory V2 / Decision Trace.
# Must produce vectors of NEO4J_EMBEDDING_DIM dimensions.
GRAPHIFY_EMBEDDING_MODEL=gemini-embedding-001

# Gemini chat model used for metadata extraction, decision-trace classification,
# iteration metadata. Cheap fast model — 2.5 Flash is the sweet spot.
GRAPHIFY_GEMINI_MODEL=gemini-2.5-flash


# =============================================================================
# Appendix: vendored Graphify package
# =============================================================================
#
# vendor/graphify/ is a vendored copy of the Graphify CLI (used by the
# bridge layer to extract repo structure). Graphify reads its OWN set of
# env vars (GRAPHIFY_OUT, GRAPHIFY_FORCE, GRAPHIFY_TRIAGE_BACKEND,
# GRAPHIFY_TRIAGE_MODEL, GRAPHIFY_OLLAMA_*, GRAPHIFY_GOOGLE_WORKSPACE,
# GRAPHIFY_WHISPER_*, GRAPHIFY_CLAUDE_CLI_PARALLEL, GRAPHIFY_VIZ_NODE_LIMIT,
# CLAUDE_CONFIG_DIR, DEEPSEEK_API_KEY, MOONSHOT_API_KEY, OLLAMA_BASE_URL,
# OLLAMA_MODEL, AWS_*, NO_COLOR, …). None are required for Constellax to
# boot — Graphify uses sane defaults. Override only if you're customizing
# graph extraction; see vendor/graphify/ docs for the full list.
